{
  "version": 3,
  "framework": {
    "name": "nitro",
    "version": "3.0.260415-beta"
  },
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "headers": {
        "Cache-Control": "no-cache"
      },
      "src": "/(.*)"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/(?:.*))",
      "dest": "/__server"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}